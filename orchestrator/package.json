{
  "name": "fn3-orchestrator",
  "version": "1.0.0",
  "description": "FN3 Agentic Workforce Orchestrator",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "worker": "tsx src/worker.ts",
    "workers": "tsx src/spawn-workers.ts",
    "typecheck": "tsc --noEmit",
    "videos:gen": "tsx scripts/run-drive-credit-videos.ts",
    "videos:frames": "tsx scripts/generate-scene-frames.ts",
    "videos:render": "tsx scripts/render-videos-ffmpeg.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "latest",
    "@supabase/supabase-js": "^2.39.0",
    "node-cron": "^3.0.3",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
